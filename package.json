{
  "name": "dockyard-cli",
  "version": "0.1.0",
  "description": "Platform-agnostic infrastructure as code for PaaS. Manage Dokploy, Railway, and other platforms from a config file.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "dac": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/dac",
    "test": "bun test"
  },
  "keywords": [
    "dokploy",
    "paas",
    "infrastructure-as-code",
    "iac",
    "deploy",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nu11ified/Dockyard.git"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  }
}
